{
  "buildCommand": "pnpm --filter @workspace/admin-panel run build",
  "outputDirectory": "artifacts/admin-panel/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "build": {
    "env": {
      "VITE_API_URL": "https://isobel-bendable-unpurely.ngrok-free.dev"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
