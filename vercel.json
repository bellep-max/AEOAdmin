{
  "buildCommand": "pnpm --filter @workspace/admin-panel run build",
  "outputDirectory": "artifacts/admin-panel/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://isobel-bendable-unpurely.ngrok-free.dev/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
